{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/coding-agent-failure-atlas/case.schema.json",
  "title": "CodingAgentFailureCase",
  "type": "object",
  "required": [
    "case_id",
    "title",
    "split",
    "primary_failure_mode",
    "severity",
    "task_family",
    "risk_surface",
    "lifecycle_stage",
    "detectability",
    "trace",
    "evidence",
    "intervention_point",
    "safe_counterfactual",
    "monitor_targets",
    "decision"
  ],
  "properties": {
    "case_id": { "type": "string", "pattern": "^CAF-[0-9]{4}$" },
    "title": { "type": "string" },
    "split": { "type": "string", "enum": ["train", "dev", "test"] },
    "primary_failure_mode": { "type": "string" },
    "secondary_failure_modes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "severity": {
      "type": "string",
      "enum": ["info", "low", "medium", "high", "critical"]
    },
    "task_family": { "type": "string" },
    "risk_surface": { "type": "string" },
    "lifecycle_stage": { "type": "string" },
    "detectability": {
      "type": "string",
      "enum": ["pattern", "semantic", "cross_event", "contextual"]
    },
    "trace": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["event_id", "actor", "action", "content"],
        "additionalProperties": true,
        "properties": {
          "event_id": { "type": "string" },
          "actor": { "type": "string" },
          "action": { "type": "string" },
          "content": { "type": "string" }
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["event_id", "excerpt", "rationale"],
        "properties": {
          "event_id": { "type": "string" },
          "excerpt": { "type": "string" },
          "rationale": { "type": "string" }
        }
      }
    },
    "intervention_point": { "type": "string" },
    "safe_counterfactual": { "type": "string" },
    "monitor_targets": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "decision": { "type": "string", "enum": ["allow", "warn", "block"] },
    "source_type": { "type": "string" },
    "release_notes": { "type": "string" }
  }
}

